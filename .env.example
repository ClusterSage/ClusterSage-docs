APP_ENV=development
APP_NAME=ClusterSage
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://clusterwatch:clusterwatch@postgres:5432/clusterwatch
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AGENT_TOKEN_SECRET=change-me-agent-token-secret
AGENT_TOKEN_EXPIRE_HOURS=720
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true;DevelopmentStorageProxyUri=http://azurite
AZURE_STORAGE_CONTAINER=clusterwatch-data
AZURE_SERVICEBUS_CONNECTION_STRING=
AZURE_SERVICEBUS_FULLY_QUALIFIED_NAMESPACE=
CLUSTER_CONNECTED_QUEUE_NAME=cluster-connected
AZURE_COMMUNICATION_EMAIL_CONNECTION_STRING=
AZURE_COMMUNICATION_EMAIL_ENDPOINT=
EMAIL_SENDER_ADDRESS=
LOG_BATCH_MAX_SIZE_MB=10
LOG_RETENTION_DAYS=30
CORS_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=ClusterSage
